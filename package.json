{
  "name": "warp-speed-init",
  "appId": "warp-speed",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "eslint src && tsc && vite build && node scripts/build-worker.mjs && cp -r assets/js dist/assets/",
    "preview": "vite preview",
    "lint": "eslint src --ext .tsx --ext .ts --ext .jsx --ext .js",
    "refmt": "prettier --config ./.prettierrc --write ./src/**/*.{ts,tsx,css}",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.tsx": [
      "node scripts/check-file-lines.mjs --max 400"
    ],
    "src/**/*.{ts,tsx}": [
      "eslint"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@fuxi/danqing-components": "^0.0.18",
    "@fuxi/danqing-sdk": "^0.0.11",
    "@fuxi/eevee-hooks": "^5.3.2",
    "@fuxi/eevee-icon": "^0.1.2",
    "@fuxi/eevee-tracker-starter": "^0.1.38",
    "@fuxi/eevee-ui": "^3.15.0",
    "@supabase/supabase-js": "^2.49.1",
    "antd": "^5.12.0",
    "axios": "^1.7.7",
    "classnames": "^2.3.2",
    "dotenv": "^16.4.7",
    "jotai": "^2.10.1",
    "js-base64": "^3.7.7",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "three": "^0.159.0"
  },
  "devDependencies": {
    "@fuxi/eslint-config-fuxi": "^2.8.3",
    "@fuxi/uno-config": "^2.4.0",
    "@fuxi/vite-plugin-classnames-bind": "^0.1.9",
    "@ianvs/prettier-plugin-sort-imports": "^4.1.1",
    "@types/js-base64": "^3.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.10",
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.8",
    "@types/react-dom": "^18.2.4",
    "@vitejs/plugin-basic-ssl": "^1.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.12.0",
    "husky": "^9.1.7",
    "less": "^4.2.0",
    "lint-staged": "^15.2.10",
    "open": "^10.1.0",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^5.9.0",
    "typescript": "^5.4.5",
    "unocss": "^66.5.10",
    "vite": "^5.4.11"
  }
}
