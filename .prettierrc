{
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "jsxBracketSameLine": true,
  "arrowParens": "avoid",
  "printWidth": 150,
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^node:",
    "^(fs|path|url|module|os|crypto|util|stream|events|buffer|process|child_process|worker_threads|cluster|net|http|https|dns|zlib|readline|repl|vm|assert|querystring|string_decoder|timers|tty|v8|perf_hooks)$",
    "^react",
    "<THIRD_PARTY_MODULES>",
    "^@fuxi/",
    "",
    "^@/",
    "",
    "^(?!.*[.](css|less|scss|sass)$)[./].*$",
    "[.](css|less|scss|sass)$"
  ]
}
